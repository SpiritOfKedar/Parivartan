PORT=8788
WEB_ORIGIN=http://localhost:5174

# Neon Postgres (https://neon.tech) — use the pooled connection string
DATABASE_URL=

# Upstash Redis REST API (https://upstash.com) — for API-side queue ops
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Redis protocol URL (rediss://...) for BullMQ workers later
# UPSTASH_REDIS_URL=

# Backblaze B2 (S3-compatible) — free tier includes 10 GB storage
# Create a bucket + Application Key at https://www.backblaze.com/b2/cloud-storage.html
# Use a key restricted to this bucket (read + write + delete).
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_REGION=us-west-004
B2_PRESIGN_EXPIRES_IN=3600
B2_UPLOAD_PREFIX=incoming
B2_OUTPUT_PREFIX=outputs
